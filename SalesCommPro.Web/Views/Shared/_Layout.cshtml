<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SalesCommPro</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SalesCommPro.Web.styles.css" asp-append-version="true" />
</head>
<body style="background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);">

    <header>
        <nav class="navbar navbar-dark bg-dark shadow-sm mb-4">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-white" asp-controller="Commission" asp-action="Index">
                    SalesCommPro
                </a>
            </div>
        </nav>
    </header>

    <div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
        <main role="main" class="w-100">
            @RenderBody()
        </main>
    </div>

    <footer class="text-center text-light mt-4 mb-3">
        &copy; 2026 - SalesCommPro
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>