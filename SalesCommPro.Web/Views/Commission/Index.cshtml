@model SalesCommPro.Web.Models.CommissionModel

<div class="d-flex justify-content-center align-items-center" style="height: 100%;">
    <div class="card shadow-lg p-4" style="width: 400px; border-radius: 15px;">

        <h3 class="text-center mb-4">Sales Commission</h3>

        <form method="post">

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label class="form-label">Ventas</label>
                <input class="form-control"
                       type="number"
                       step="0.01"
                       asp-for="Sales" />
                <span asp-validation-for="Sales" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Descuentos</label>
                <input class="form-control"
                       type="number"
                       step="0.01"
                       asp-for="Discount" />
                <span asp-validation-for="Discount" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">País</label>
                <select class="form-select" asp-for="Country">
                    <option value="">Select country</option>
                    <option value="India">India</option>
                    <option value="US">United States</option>
                    <option value="UK">United Kingdom</option>
                </select>
                <span asp-validation-for="Country" class="text-danger"></span>
            </div>

            <button class="btn btn-primary w-100">Calcular</button>
        </form>

        @if (Model.HasResult)
        {
            <div class="alert alert-success mt-3 text-center">
                <strong>$@Model.Result.ToString("N2")</strong>
            </div>
        }

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}